{
  "name": "eleks",
  "version": "1.0.0",
  "description": "AIDA64 System Monitor -> Home Assistant",
  "author": "Nathan Baker <pcnate@gmail.com>",
  "license": "MIT",
  "scripts": {
    "start": "copy /Y dist\\eleks-monitor.exe dist\\eleks-monitor.running.exe >nul && .\\dist\\eleks-monitor.running.exe",
    "start:daemon": "copy /Y dist\\eleks-monitor.exe dist\\eleks-monitor.running.exe >nul && .\\dist\\eleks-monitor.running.exe -d",
    "build": "ts-node bin/build.ts",
    "create-installer": "iscc build/setup.iss",
    "version": "npm run build && npm run create-installer"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "@semantic-release/exec": "^6.0.3",
    "semantic-release": "^24.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1"
  }
}
