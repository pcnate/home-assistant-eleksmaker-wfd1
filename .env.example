MACHINE_NAME=your_machine_name
HA_URL=http://your-home-assistant:8123/api/states/
HA_TOKEN=your_long_lived_access_token

# AIDA64 Sensor IDs (defaults shown, change to match your hardware)
SENSOR_CPU_USAGE=SCPUUTI
SENSOR_CPU_TEMP=TCPU
SENSOR_CPU_CLOCK=SCPUCLK
SENSOR_GPU_USAGE=SGPU1UTI
SENSOR_GPU_TEMP=TGPU1
SENSOR_GPU_TEMP_HOT=TGPU1HOT
SENSOR_RAM_USAGE=SMEMUTI
SENSOR_DISK_ACTIVITY=SDSK1ACT
SENSOR_DISK_READ=SDSK1READSPD
SENSOR_DISK_WRITE=SDSK1WRITESPD
SENSOR_BATTERY_PERC=SBATTLVL
SENSOR_BATTERY_VOLT=VBATT
SENSOR_POWER_STATE=SPWRSTATE
